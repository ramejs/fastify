{
  "name": "@ramejs/fastify",
  "version": "0.2.0",
  "description": "JSX-driven Fastify server construction powered by @ramejs/rame.",
  "keywords": [
    "fastify",
    "fastify-plugin",
    "jsx",
    "routing",
    "server",
    "declarative",
    "schema",
    "zod",
    "typescript",
    "rest",
    "api"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "clean": "rm -rf dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@fastify/websocket": ">=11.0.0",
    "@ramejs/rame": ">=0.2.1",
    "fastify": ">=5.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@fastify/websocket": {
      "optional": true
    }
  },
  "devDependencies": {
    "@fastify/websocket": "^11.2.0",
    "@ramejs/rame": ">=0.2.1",
    "@types/bun": "^1.3.11",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fastify": "^5.2.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
