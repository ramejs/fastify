{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": [],
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "declarationMap": true,
    "removeComments": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": ["node_modules", "examples", "dist", "src/__tests__"]
}
